# ============================================
# Kaven's Blog — Caddyfile (HTTPS 自动证书)
# Astro SSR standalone mode
# ============================================
# 使用方法:
#   1. 将域名 DNS 解析到服务器 IP
#   2. 将 your-domain.com 替换为你的域名
#   3. docker compose -f docker-compose.caddy.yml up -d
#
your-domain.com {
    # 上传图片 (直接从卷读取)
    handle /uploads/* {
        root * /data
        file_server
    }

    # 所有请求反向代理到 Astro SSR
    handle {
        reverse_proxy app:4321
    }

    # 安全头
    header X-Frame-Options "SAMEORIGIN"
    header X-Content-Type-Options "nosniff"
    header X-XSS-Protection "1; mode=block"

    # 静态资源缓存
    @static {
        path /uploads/*
    }
    header @static Cache-Control "public, max-age=604800"
}

# 管理员账号（固定）
ADMIN_USERNAME=kavenyyds

# 管理员密码（固定）
ADMIN_PASSWORD=jlhj123456

# Token 签名密钥（固定）
AUTH_SECRET=d8e3f1a7b2c4e5f6a0b1c2d3e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3

# 服务端口（默认 3000，Docker 内部使用，对外由 Nginx 暴露 80）

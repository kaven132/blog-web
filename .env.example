# ==========================================
# Kaven's Blog — 环境变量配置
# 复制此文件为 .env 并修改对应值
# ==========================================

# 管理员账号（固定）
ADMIN_USERNAME=admin

# 管理员密码（固定）
ADMIN_PASSWORD=123456

# Token 签名密钥（固定）
AUTH_SECRET=

# 服务端口（默认 3000，Docker 内部使用，对外由 Nginx 暴露 80）
PORT=3000

# 设为 true 可在本地开发时使用 Node 直接服务静态文件（无需 Nginx）
# NO_STATIC=false

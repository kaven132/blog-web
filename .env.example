# ==========================================
# Kaven's Blog — 环境变量配置
# 复制此文件为 .env 并修改对应值
# Astro SSR + Drizzle ORM + SQLite
# ==========================================

# 管理员账号（选填，默认 admin）
ADMIN_USERNAME=admin

# 管理员密码（必填，强烈建议修改）
ADMIN_PASSWORD=123456

# JWT 签名密钥（选填，留空自动生成）
AUTH_SECRET=

# Astro SSR 端口（Docker 内部使用，无需修改）
PORT=4321

# Docker 对外暴露端口（默认 80，冲突时改为其他端口如 8080）
# PORT_EXPOSE=80

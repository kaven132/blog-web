# ==========================================
# Kaven's Blog — 环境变量配置
# 复制此文件为 .env 并修改对应值
# 或运行 ./deploy.sh 自动创建
# ==========================================

# 管理员账号（选填，默认 admin）
ADMIN_USERNAME=admin

# 管理员密码（必填，强烈建议修改）
ADMIN_PASSWORD=123456

# Token 签名密钥（选填，留空自动生成 64 位随机 hex）
AUTH_SECRET=

# Node 服务端口（Docker 内部使用，无需修改）
PORT=3000

# 设为 true 可在本地开发时使用 Node 直接服务静态文件（无需 Nginx）
# 生产环境请保持取消注释或设为 true
# NO_STATIC=false

# Docker 对外暴露端口（默认 80，冲突时改为其他端口如 8080）
# PORT_EXPOSE=80

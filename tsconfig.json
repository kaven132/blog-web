{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "astro.config.ts", "drizzle.config.ts"],
  "exclude": ["node_modules", "dist"]
}

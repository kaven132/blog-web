---
// Home page — SSR-rendered article list
// Query params: category, subcategory, search, sort (same as GET /api/articles)
import BaseLayout from "../components/layout/BaseLayout.astro";
import ArticleGrid from "../components/article/ArticleGrid.astro";
import { db } from "../lib/db";
import { articles } from "../db/schema";
import { eq, like, or, and, desc, asc } from "drizzle-orm";
import { articleToJSON } from "../lib/utils";

// Parse query params from request URL
const url = new URL(Astro.request.url);
const category = url.searchParams.get("category") || "";
const subcategory = url.searchParams.get("subcategory") || "";
const search = url.searchParams.get("search") || "";
const sort = url.searchParams.get("sort") || "newest";

// Helper: build URL for sort switching (preserving current filters)
function buildSortUrl(newSort: string): string {
  const params = new URLSearchParams();
  if (category && category !== "all") params.set("category", category);
  if (subcategory && subcategory !== "all") params.set("subcategory", subcategory);
  if (search.trim()) params.set("search", search.trim());
  params.set("sort", newSort);
  return "/?" + params.toString();
}

// Build query conditions
const conditions = [];

if (category && category !== "all") {
  conditions.push(eq(articles.category, category));
}

if (subcategory && subcategory !== "all") {
  conditions.push(eq(articles.subcategory, subcategory));
}

if (search.trim()) {
  const q = "%" + search.trim() + "%";
  conditions.push(
    or(
      like(articles.title, q),
      like(articles.summary, q),
      like(articles.content, q),
      like(articles.tags, q),
    )!,
  );
}

let query = db.select().from(articles).$dynamic();

if (conditions.length > 0) {
  query = query.where(and(...conditions));
}

// Order: pinned first, then by sort param
switch (sort) {
  case "oldest":
    query = query.orderBy(desc(articles.isPinned), asc(articles.createdAt));
    break;
  case "title":
    query = query.orderBy(desc(articles.isPinned), asc(articles.title));
    break;
  case "newest":
  default:
    query = query.orderBy(desc(articles.isPinned), desc(articles.createdAt));
}

const rows = query.all();
const articleList = rows.map(articleToJSON);

// Page title
const pageTitle = category && category !== "all"
  ? `${category} · Kaven的博客`
  : "Kaven的个人博客";
---

<BaseLayout pageTitle={pageTitle}>
  <!-- Toolbar -->
  <div class="toolbar">
    <div class="search-box">
      <i class="fa-solid fa-magnifying-glass"></i>
      <form action="/" method="get" class="search-form-inline">
        {category && category !== "all" && (
          <input type="hidden" name="category" value={category} />
        )}
        {subcategory && subcategory !== "all" && (
          <input type="hidden" name="subcategory" value={subcategory} />
        )}
        <input
          type="text"
          id="search-input"
          name="search"
          placeholder="搜索文章标题或内容..."
          value={search}
        />
      </form>
    </div>
    <div class="toolbar-actions">
      <select
        id="sort-select"
        class="select-sm"
        onchange={`window.location.href='${buildSortUrl("__SORT__")}'.replace('__SORT__', this.value)`}
      >
        <option value="newest" selected={sort === "newest"}>最新优先</option>
        <option value="oldest" selected={sort === "oldest"}>最早优先</option>
        <option value="title" selected={sort === "title"}>按标题</option>
      </select>
    </div>
  </div>

  <!-- Article Grid -->
  <ArticleGrid articles={articleList} />
</BaseLayout>

---
// Article detail page — SSR-rendered
// URL: /article/:id — renders full article + comments
import BaseLayout from "../../components/layout/BaseLayout.astro";
import LikeButton from "../../components/react/LikeButton";
import CommentSection from "../../components/react/CommentSection";
import { db } from "../../lib/db";
import { articles, comments } from "../../db/schema";
import { eq, desc } from "drizzle-orm";
import { articleToJSON } from "../../lib/utils";

const { id } = Astro.params;

// Fetch article
const row = db
  .select()
  .from(articles)
  .where(eq(articles.id, id!))
  .get();

if (!row) {
  return new Response(
    `<!DOCTYPE html><html lang="zh-CN"><head><meta charset="UTF-8" /><title>404 · Kaven的博客</title></head><body style="display:flex;align-items:center;justify-content:center;min-height:100vh;font-family:sans-serif"><div style="text-align:center"><h1 style="font-size:4rem;color:#4f46e5;margin:0">404</h1><p style="color:#64748b;margin:1rem 0">文章不存在或已被删除</p><a href="/" style="color:#4f46e5">← 返回首页</a></div></body></html>`,
    { status: 404, headers: { "Content-Type": "text/html" } },
  );
}

const article = articleToJSON(row);

// Fetch comments
const commentList = db
  .select()
  .from(comments)
  .where(eq(comments.articleId, id!))
  .orderBy(desc(comments.createdAt))
  .all();

// Format date helper
function formatFullDate(dateStr: string): string {
  const d = new Date(dateStr);
  return d.toLocaleDateString("zh-CN", {
    year: "numeric",
    month: "long",
    day: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });
}
---

<BaseLayout pageTitle={`${article.title} · Kaven的博客`}>
  <article class="article-detail bg-bg-card shadow-default rounded-default border border-border p-6 md:p-8">
    <!-- Header -->
    <header class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        {article.category && (
          <a
            href={`/?category=${encodeURIComponent(article.category)}`}
            class="text-xs font-medium text-primary bg-primary-light px-2.5 py-0.5 rounded-full hover:bg-primary hover:text-white transition-colors"
          >
            {article.category}
          </a>
        )}
        {article.subcategory && (
          <span class="text-xs text-text-muted">
            <i class="fa-solid fa-chevron-right mx-1"></i>
            {article.subcategory}
          </span>
        )}
        {article.isPinned ? (
          <span class="text-xs text-warning ml-auto" title="已置顶">
            <i class="fa-solid fa-thumbtack"></i> 置顶
          </span>
        ) : null}
      </div>

      <h1 class="text-2xl md:text-3xl font-bold text-text mb-3 leading-tight">
        {article.title}
      </h1>

      <div class="flex items-center gap-4 text-sm text-text-muted">
        <time datetime={article.createdAt} class="flex items-center gap-1">
          <i class="fa-regular fa-calendar"></i>
          {formatFullDate(article.createdAt)}
        </time>
        {article.updatedAt !== article.createdAt && (
          <span class="flex items-center gap-1">
            <i class="fa-solid fa-pen"></i>
            更新于 {formatFullDate(article.updatedAt)}
          </span>
        )}
        <span class="flex items-center gap-1">
          <i class="fa-regular fa-heart text-danger"></i>
          {article.likesCount}
        </span>
        <span class="flex items-center gap-1">
          <i class="fa-regular fa-comment"></i>
          {commentList.length}
        </span>
      </div>
    </header>

    <!-- Cover image -->
    {article.coverImage && (
      <div class="mb-6 rounded-default overflow-hidden">
        <img
          src={article.coverImage}
          alt={article.title}
          class="w-full max-h-96 object-cover"
        />
      </div>
    )}

    <!-- Article content (admin-authored HTML — rendered with set:html) -->
    <div class="article-content prose-custom mb-8" set:html={article.content} />

    <!-- Tags -->
    {article.tags.length > 0 && (
      <div class="article-tags flex flex-wrap gap-2 mb-8 pt-6 border-t border-border">
        {article.tags.map((tag: string) => (
          <span class="text-xs bg-bg text-text-secondary px-3 py-1.5 rounded-full border border-border">
            #{tag}
          </span>
        ))}
      </div>
    )}

    <!-- Like & Comment bar (React Island: LikeButton w/ optimistic update) -->
    <div class="article-engage-bar flex items-center gap-4 py-4 border-t border-border">
      <LikeButton
        client:load
        articleId={article.id}
        initialCount={article.likesCount}
        initialLiked={false}
      />
      <div class="engage-btn flex items-center gap-1.5 text-text-secondary">
        <i class="fa-regular fa-comment text-lg"></i>
        <span>{commentList.length}</span>
      </div>
    </div>
  </article>

  <!-- Comments Section (React Island) -->
  <div class="comments-section-wrapper mt-5">
    <CommentSection
      client:visible
      articleId={article.id}
      initialComments={commentList}
    />
  </div>
</BaseLayout>

<style>
  /* Article content styling (matches original design) */
  .prose-custom :global(h3) {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 1.5rem 0 0.75rem;
    color: var(--color-text);
    padding-left: 0.75rem;
    border-left: 4px solid var(--color-primary);
    line-height: 1.4;
  }
  .prose-custom :global(p) {
    margin: 0.75rem 0;
    line-height: 1.8;
    color: var(--color-text);
  }
  .prose-custom :global(blockquote) {
    margin: 1rem 0;
    padding: 0.75rem 1rem;
    background: var(--color-primary-light);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--color-text-secondary);
  }
  .prose-custom :global(code) {
    background: var(--color-bg);
    padding: 0.15em 0.4em;
    border-radius: 3px;
    font-size: 0.9em;
    font-family: 'Consolas', 'Monaco', monospace;
    color: var(--color-danger);
  }
  .prose-custom :global(pre) {
    background: #1e293b;
    color: #e2e8f0;
    padding: 1rem 1.25rem;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    margin: 1rem 0;
    font-size: 0.88rem;
    line-height: 1.6;
  }
  .prose-custom :global(pre code) {
    background: transparent;
    color: inherit;
    padding: 0;
    font-size: inherit;
  }
  .prose-custom :global(ul), .prose-custom :global(ol) {
    margin: 0.75rem 0;
    padding-left: 1.5rem;
  }
  .prose-custom :global(li) {
    margin: 0.25rem 0;
    line-height: 1.7;
  }
  .prose-custom :global(strong) {
    font-weight: 600;
    color: var(--color-text);
  }
  .prose-custom :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .prose-custom :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 1.5rem 0;
  }
  .prose-custom :global(img) {
    max-width: 100%;
    border-radius: var(--radius-sm);
    margin: 1rem 0;
  }
</style>

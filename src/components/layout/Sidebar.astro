---
// Sidebar.astro — Left sidebar with profile, categories, and game news (SSR)
import ProfileCard from "../profile/ProfileCard.astro";
import GameNews from "../game-news/GameNews.astro";
import { db } from "../../lib/db";
import { articles, categoryTree } from "../../db/schema";
import { count, isNotNull, asc } from "drizzle-orm";

const categoryRows = db
  .select({ category: articles.category, cnt: count() })
  .from(articles)
  .where(isNotNull(articles.category))
  .groupBy(articles.category)
  .orderBy(asc(articles.category))
  .all()
  .filter((r): r is { category: string; cnt: number } => r.category !== null && r.category !== "");

const treeRows = db
  .select().from(categoryTree)
  .orderBy(asc(categoryTree.parent), asc(categoryTree.child))
  .all();

const tree: Record<string, string[]> = {};
for (const row of treeRows) {
  if (!tree[row.parent]) tree[row.parent] = [];
  tree[row.parent].push(row.child);
}

const url = new URL(Astro.request?.url || "http://localhost:4321");
const activeCategory = url.searchParams.get("category") || "all";
---

<aside class="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-header-title">Kaven的博客</span>
    <button class="sidebar-close" id="sidebar-close" title="关闭侧边栏" aria-label="关闭侧边栏">
      <i class="fa-solid fa-chevron-left"></i>
    </button>
  </div>

  <ProfileCard />

  <!-- Categories -->
  <div class="sidebar-card">
    <h3 class="sidebar-card-title">
      <i class="fa-solid fa-folder"></i> 文章分类
    </h3>
    <nav class="category-nav" id="category-list">
      <a href="/" class={`cat-link${activeCategory === "all" ? " active" : ""}`}>
        <span class="cat-icon"><i class="fa-solid fa-border-all"></i></span>
        <span class="cat-label">全部</span>
        <span class="cat-count">{categoryRows.reduce((s, r) => s + r.cnt, 0)}</span>
      </a>
      {categoryRows.map((cat) => {
        const isActive = cat.category === activeCategory;
        const hasSubs = (tree[cat.category] || []).length > 0;
        return (
          <a
            href={`/?category=${encodeURIComponent(cat.category)}`}
            class={`cat-link${isActive ? " active" : ""}`}
          >
            <span class="cat-icon">
              <i class={`fa-solid ${hasSubs ? 'fa-folder-tree' : 'fa-folder'}`}></i>
            </span>
            <span class="cat-label">{cat.category}</span>
            <span class="cat-count">{cat.cnt}</span>
          </a>
        );
      })}
    </nav>
  </div>

  <GameNews />
</aside>

<style>
  .category-nav {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cat-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    text-decoration: none;
    color: var(--color-text, #1e293b);
    font-size: 0.9rem;
    font-weight: 500;
    transition: all 0.18s ease;
    cursor: pointer;
    position: relative;
    border: 1px solid transparent;
  }
  .cat-link:hover {
    background: var(--color-primary-light, #eef2ff);
    color: var(--color-primary, #4f46e5);
    border-color: var(--color-primary-light, #eef2ff);
  }
  .cat-link.active {
    background: var(--color-primary-light, #eef2ff);
    color: var(--color-primary, #4f46e5);
    font-weight: 600;
    border-color: var(--color-primary, #4f46e5);
    box-shadow: 0 0 0 1px var(--color-primary, #4f46e5) inset;
  }
  .cat-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 6px;
    background: var(--color-bg, #f8fafc);
    font-size: 0.75rem;
    color: var(--color-text-muted, #94a3b8);
    flex-shrink: 0;
    transition: all 0.18s ease;
  }
  .cat-link.active .cat-icon {
    background: var(--color-primary, #4f46e5);
    color: #fff;
  }
  .cat-link:hover .cat-icon {
    background: var(--color-primary, #4f46e5);
    color: #fff;
  }
  .cat-label {
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .cat-count {
    font-size: 0.72rem;
    font-weight: 600;
    background: var(--color-bg, #f8fafc);
    color: var(--color-text-muted, #94a3b8);
    padding: 2px 9px;
    border-radius: 20px;
    min-width: 24px;
    text-align: center;
    flex-shrink: 0;
    transition: all 0.18s ease;
  }
  .cat-link.active .cat-count {
    background: var(--color-primary, #4f46e5);
    color: #fff;
  }
  .cat-link:hover .cat-count {
    background: var(--color-primary, #4f46e5);
    color: #fff;
  }
</style>

---
// Sidebar.astro — Left sidebar with profile, categories, and game news (SSR)
import ProfileCard from "../profile/ProfileCard.astro";
import GameNews from "../game-news/GameNews.astro";
import { db } from "../../lib/db";
import { articles, categoryTree } from "../../db/schema";
import { count, isNotNull, asc } from "drizzle-orm";

// Get category list with article counts (for sidebar category filter)
const categoryRows = db
  .select({
    category: articles.category,
    cnt: count(),
  })
  .from(articles)
  .where(isNotNull(articles.category))
  .groupBy(articles.category)
  .orderBy(asc(articles.category))
  .all()
  .filter((r): r is { category: string; cnt: number } => r.category !== null && r.category !== "");

// Get category tree
const treeRows = db
  .select()
  .from(categoryTree)
  .orderBy(asc(categoryTree.parent), asc(categoryTree.child))
  .all();

// Group tree by parent
const tree: Record<string, string[]> = {};
for (const row of treeRows) {
  if (!tree[row.parent]) tree[row.parent] = [];
  tree[row.parent].push(row.child);
}

// Current category/subcategory from URL (passed via Astro.url)
const url = new URL(Astro.request?.url || "http://localhost:4321");
const activeCategory = url.searchParams.get("category") || "all";
const activeSubcategory = url.searchParams.get("subcategory") || "all";
---

<aside class="sidebar">
  <div class="sidebar-header">
    <span class="sidebar-header-title">Kaven的博客</span>
    <button class="sidebar-close" id="sidebar-close" title="关闭侧边栏" aria-label="关闭侧边栏">
      <i class="fa-solid fa-chevron-left"></i>
    </button>
  </div>

  <!-- Profile Card -->
  <ProfileCard />

  <!-- Categories -->
  <div class="sidebar-card">
    <h3 class="sidebar-card-title">
      <i class="fa-solid fa-folder"></i> 文章分类
    </h3>
    <ul class="category-list" id="category-list">
      <li class={`category-item${activeCategory === "all" ? " active" : ""}`}>
        <a href="/" data-category="all">全部</a>
      </li>
      {categoryRows.map((cat) => {
        const isActive = cat.category === activeCategory;
        const subcategories = tree[cat.category] || [];
        return (
          <li class={`category-item${isActive ? " active" : ""}`}>
            <a
              href={`/?category=${encodeURIComponent(cat.category)}`}
              data-category={cat.category}
            >
              {cat.category}
              <span class="category-count">{cat.cnt}</span>
            </a>
            {subcategories.length > 0 && isActive && (
              <ul class="subcategory-list mt-1 ml-4">
                <li class={`category-item text-sm${activeSubcategory === "all" ? " active" : ""}`}>
                  <a href={`/?category=${encodeURIComponent(cat.category)}`} data-subcategory="all">
                    全部
                  </a>
                </li>
                {subcategories.map((sub: string) => (
                  <li class={`category-item text-sm${sub === activeSubcategory ? " active" : ""}`}>
                    <a
                      href={`/?category=${encodeURIComponent(cat.category)}&subcategory=${encodeURIComponent(sub)}`}
                      data-subcategory={sub}
                    >
                      {sub}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        );
      })}
    </ul>
  </div>

  <!-- Game News -->
  <GameNews />
</aside>
